# Production environment template
#
# Copy values from an approved secret manager at deploy time. Do not commit real
# secrets, managed service credentials, private keys, or inline token material.

# Required release/image inputs
RELEASE_VERSION=git-sha-or-release-tag
PRODUCTION_APP_IMAGE=ghcr.io/lottery-app/lottery-app:${RELEASE_VERSION}
PRODUCTION_AUTH_SERVICE_IMAGE=ghcr.io/lottery-app/auth-service:${RELEASE_VERSION}
PRODUCTION_GAME_ENGINE_IMAGE=ghcr.io/lottery-app/game-engine:${RELEASE_VERSION}
PRODUCTION_LEDGER_SERVICE_IMAGE=ghcr.io/lottery-app/ledger-service:${RELEASE_VERSION}
PRODUCTION_CREDIT_WALLET_SERVICE_IMAGE=ghcr.io/lottery-app/credit-wallet-service:${RELEASE_VERSION}
PRODUCTION_SETTLEMENT_SERVICE_IMAGE=ghcr.io/lottery-app/settlement-service:${RELEASE_VERSION}
PRODUCTION_OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.115.1

# Required public URLs
PRODUCTION_HOSTNAME=app.your-production-domain.tld
APP_BASE_URL=https://app.your-production-domain.tld
PUBLIC_APP_URL=https://app.your-production-domain.tld

# Required managed services
# PostgreSQL must require TLS. Use separate runtime and migration variables.
DATABASE_URL=postgresql://runtime_user:credential@managed-postgres-host:5432/database?sslmode=require
MIGRATIONS_DATABASE_URL=postgresql://migration_user:credential@managed-postgres-host:5432/database?sslmode=require
DATABASE_SSL_MODE=require
# Redis must use TLS and authenticated managed-provider credentials.
REDIS_URL=rediss://:credential@managed-redis-host:6380/0
REDIS_TLS=true
# CloudAMQP/RabbitMQ must use AMQPS and authenticated broker credentials.
RABBITMQ_URL=amqps://user:credential@managed-rabbitmq-host/vhost
RABBITMQ_EXCHANGE_NAME=lottery.events
MANAGED_POSTGRES_REQUIRED=true
MANAGED_REDIS_REQUIRED=true
MANAGED_RABBITMQ_REQUIRED=true
MANAGED_DEPENDENCY_READINESS_REQUIRED=true

# Optional CloudAMQP management API access for later operations automation.
RABBITMQ_MANAGEMENT_URL=https://managed-rabbitmq-host/api
RABBITMQ_MANAGEMENT_TOKEN_REF=infisical://production/rabbitmq/management-token

# Required production migration governance evidence
# These are consumed by the manual migration-runner profile and do not enable
# automatic production deployment.
PRODUCTION_MIGRATION_BACKUP_CHECKPOINT=pitr-checkpoint-or-backup-id
PRODUCTION_MIGRATION_STAGING_REHEARSAL_EVIDENCE=staging-rehearsal-evidence-uri-or-digest
PRODUCTION_MIGRATION_APPROVAL_TOKEN=approval-record-or-change-ticket-id
PRODUCTION_MIGRATION_APPROVED=false
PRODUCTION_MIGRATION_DRIFT_CHECK=completed
PRODUCTION_MIGRATION_DRIFT_RESULT=no-drift
PRODUCTION_MIGRATION_EVIDENCE_DIR=.qa/production-migration-governance

# Required Supabase/app data access
SUPABASE_URL=https://managed-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=secret-manager-reference-required
SUPABASE_ANON_KEY=secret-manager-reference-required
NEXT_PUBLIC_SUPABASE_URL=https://managed-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=publishable-key-from-managed-project

# Required authentication runtime
AUTH_PROVIDER=auth-service
AUTH_AUTHORITY=MONOLITH
AUTH_ALLOW_INITIAL_BOOTSTRAP=false
AUTH_SERVICE_URL=http://auth-service:8080
SECURITY_ENFORCE_PRODUCTION_SECRETS=true
SECURITY_AUDIT_LEVEL=high
AUTH_SIGNING_KEY_REF=infisical://production/auth/signing-key
AUTH_REFRESH_TOKEN_SECRET_REF=infisical://production/auth/refresh-token-secret
AUTH_SESSION_SECRET_REF=infisical://production/auth/session-secret
AUTH_SERVICE_TOKEN_SIGNING_KEY_REF=infisical://production/auth/service-token-signing-key

# Required authority posture
# MONOLITH defaults remain blocked unless this explicit exception is approved for
# the deployment. SERVICE authority must still satisfy runtime guardrails.
LEDGER_AUTHORITY=MONOLITH
CREDIT_AUTHORITY=MONOLITH
SETTLEMENT_AUTHORITY=MONOLITH
ALLOW_MONOLITH_AUTHORITY_IN_PRODUCTION=false
LEDGER_COMPARISON_MODE=ENABLED
CREDIT_COMPARISON_MODE=ENABLED
SETTLEMENT_COMPARISON_MODE=ENABLED

# Required observability
# App/service/worker containers send OTLP to the internal collector. The
# collector forwards to Grafana Cloud using the endpoint and authorization
# header injected by the production secret manager at deploy time.
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=secret-manager-injected-grafana-cloud-authorization-header
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,service.version=${RELEASE_VERSION}

# Optional Caddy/Cloudflare posture marker
CADDY_CLOUDFLARE_MODE=origin
